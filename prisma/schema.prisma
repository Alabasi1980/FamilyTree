generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===========================
// ENUMS
// ===========================

enum AccountType {
  SYSTEM_ADMIN
  MEMBER
  VISITOR
}

enum VisibilityLevel {
  PUBLIC
  MEMBER
  ADMIN
  SHARED_LINK
}

enum Gender {
  MALE
  FEMALE
}

enum MarriageStatus {
  ACTIVE
  ENDED
  HISTORICAL
  UNDOCUMENTED
}

enum ParentChildRelationType {
  BIOLOGICAL
  STEP
  GUARDIANSHIP
  ADOPTIVE
  UNKNOWN
}

enum MarriageEndReason {
  DIVORCE
  DEATH_OF_SPOUSE
  ANNULMENT
  UNKNOWN
}

enum RelationConfidence {
  VERIFIED
  LIKELY
  UNVERIFIED
  DISPUTED
}

enum CrossFamilyMarriageStatus {
  PENDING_FAMILY_A
  PENDING_FAMILY_B
  APPROVED
  REJECTED
  CANCELLED
  APPLIED
}

enum FosterRelationConfidence {
  DOCUMENTED
  LIKELY
  UNDOCUMENTED
}

enum FamilyLinkType {
  KINSHIP
  IN_LAW
}

enum FamilyLinkStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EditRequestSource {
  MEMBER
  SHARE_LINK_GUEST
}

enum EditRequestType {
  ADD_PERSON
  EDIT_PERSON
  ADD_RELATION
  EDIT_RELATION
  ADD_FAMILY_INFO
  EDIT_FAMILY_INFO
}

enum TargetType {
  PERSON
  FAMILY
  RELATION
}

enum AdminRequestType {
  CREATE_FAMILY_AND_ADMINISTER
  BECOME_FAMILY_ADMIN
  JOIN_FAMILY_ADMINS
  LINK_USER_TO_PERSON
}

enum AdminRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminDecisionType {
  APPROVE_NEW_FAMILY_ADMIN
  APPROVE_JOIN_EXISTING_ADMINS
  TRANSFER_FAMILY_OWNERSHIP
  REJECT
}

enum ShareLinkTargetType {
  FAMILY
  WORKSPACE
}

enum HomelandConfidence {
  VERIFIED
  LIKELY
  UNDOCUMENTED
  UNSPECIFIED
}

enum HomelandPlaceType {
  COUNTRY
  REGION
  CITY
}

enum HomelandPlaceStatus {
  ACTIVE
  DISABLED
}

enum HomelandPlaceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BranchUnificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PersonMembershipRole {
  MARRIED_IN    // زوج/زوجة من عائلة أخرى يظهر في شجرة هذه العائلة
  BRANCH_MEMBER // فرع موحَّد — نتيجة BranchUnification
  CROSS_PARENT  // والد أو جد من عائلة أخرى مرتبط يدوياً
  DESCENDANT    // ابن أو حفيد من عائلة أخرى مرتبط عبر والد خارجي
}

enum BranchUnificationRelationship {
  FULL_SIBLINGS
  PATERNAL_SIBLINGS
  MATERNAL_SIBLINGS
}

enum NotificationType {
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_APPLIED
  COMPLAINT_SUBMITTED
  COMPLAINT_UPDATED
}

enum ComplaintType {
  ACCOUNT_ACCESS
  FAMILY_ADMINISTRATION
  DATA_CORRECTION
  PRIVACY_SAFETY
  FAMILY_LINKING
  TECHNICAL_ISSUE
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  WAITING_USER
  RESOLVED
  CLOSED
}

// ===========================
// CORE MODELS
// ===========================

model User {
  id            String      @id @default(cuid())
  name          String?
  fullName      String?
  email         String?     @unique
  emailVerified DateTime?
  phone         String?     @unique
  image         String?
  accountType   AccountType @default(VISITOR)
  passwordHash  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  // Auth
  sessions    Session[]
  accounts    Account[]

  linkedPersonId  String?
  linkedPerson    Person?  @relation("UserLinkedPerson", fields: [linkedPersonId], references: [id], onDelete: SetNull)

  // Relations
  familyAdminAssignments FamilyAdminAssignment[]
  editRequestsSubmitted  EditRequest[]           @relation("EditRequestSubmitter")
  editRequestsReviewed   EditRequest[]           @relation("EditRequestReviewer")
  adminRequestsSubmitted AdminRequest[]          @relation("AdminRequestSubmitter")
  adminRequestsReviewed  AdminRequest[]          @relation("AdminRequestReviewer")
  shareLinksCreated      ShareLink[]
  notifications          Notification[]
  complaintsSubmitted    Complaint[]             @relation("ComplaintSubmitter")
  complaintsHandled      Complaint[]             @relation("ComplaintHandler")
  homelandPlaceRequestsSubmitted HomelandPlaceRequest[] @relation("HomelandPlaceRequestSubmitter")
  homelandPlaceRequestsReviewed  HomelandPlaceRequest[] @relation("HomelandPlaceRequestReviewer")

  @@index([email])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================
// FAMILY & WORKSPACE
// ===========================

model Family {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  originSummary    String?
  historicalNotes  String?
  homelandCountry  String?
  homelandRegion   String?
  homelandCity     String?
  homelandNote     String?
  homelandConfidence HomelandConfidence @default(UNSPECIFIED)
  homelandPlaceId  String?
  isPublic                   Boolean   @default(false)
  hideFemaleMembersFromPublic Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  persons           Person[]
  personMemberships PersonFamilyMembership[]
  adminAssignments  FamilyAdminAssignment[]
  familyLinksA     FamilyLink[]            @relation("FamilyLinkA")
  familyLinksB     FamilyLink[]            @relation("FamilyLinkB")
  workspaceFamilies WorkspaceFamily[]
  editRequests     EditRequest[]
  adminRequests    AdminRequest[]
  shareLinks       ShareLink[]
  complaints       Complaint[]
  homelandPlace    HomelandPlace?       @relation(fields: [homelandPlaceId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([homelandPlaceId])
  @@index([homelandCountry, homelandRegion, homelandCity])
}

model HomelandPlace {
  id          String              @id @default(cuid())
  name        String
  normalizedName String
  slug        String
  type        HomelandPlaceType
  status      HomelandPlaceStatus @default(ACTIVE)
  parentId    String?
  aliases     String[]            @default([])
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  parent      HomelandPlace?      @relation("HomelandPlaceTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    HomelandPlace[]     @relation("HomelandPlaceTree")
  families    Family[]
  proposedAdminRequests AdminRequest[] @relation("AdminRequestProposedHomelandPlace")
  requests     HomelandPlaceRequest[]  @relation("HomelandPlaceRequestApprovedPlace")

  @@unique([parentId, normalizedName, type])
  @@index([parentId, type, status, sortOrder])
  @@index([type, status])
}

model Workspace {
  id          String    @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  families  WorkspaceFamily[]
  shareLinks ShareLink[]
}

model WorkspaceFamily {
  id          String    @id @default(cuid())
  workspaceId String
  familyId    String
  addedAt     DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  family      Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, familyId])
}

model FamilyAdminAssignment {
  id               String    @id @default(cuid())
  familyId         String
  userId           String
  isActive         Boolean   @default(true)
  assignedByUserId String?
  assignedAt       DateTime  @default(now())
  endedAt          DateTime?
  notes            String?

  family  Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId, isActive])
  @@index([userId])
}

model FamilyLink {
  id          String           @id @default(cuid())
  familyAId   String
  familyBId   String
  linkType    FamilyLinkType
  description String?
  status      FamilyLinkStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  familyA Family @relation("FamilyLinkA", fields: [familyAId], references: [id])
  familyB Family @relation("FamilyLinkB", fields: [familyBId], references: [id])

  @@unique([familyAId, familyBId])
  @@index([familyAId])
  @@index([familyBId])
}

// ===========================
// PERSON & RELATIONS
// ===========================

model Person {
  id              String          @id @default(cuid())
  familyId        String
  fullName        String
  kunya           String?
  gender          Gender
  birthYear       Int?
  birthDate       DateTime?
  birthPlace      String?
  deathYear       Int?
  deathDate       DateTime?
  isLiving        Boolean         @default(true)
  bloodType       String?
  residenceCity   String?
  address         String?
  profession      String?
  biography       String?
  photoUrl        String?
  visibilityLevel VisibilityLevel @default(PUBLIC)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  parentRelations    ParentChildRelation[] @relation("ParentPerson")
  childRelations     ParentChildRelation[] @relation("ChildPerson")
  marriagesAsPersonA MarriageRelation[]    @relation("MarriagePersonA")
  marriagesAsPersonB MarriageRelation[]    @relation("MarriagePersonB")

  linkedUsers     User[]         @relation("UserLinkedPerson")
  adminRequestsAsTarget AdminRequest[] @relation("AdminRequestTargetPerson")

  // Secondary family memberships (person appears in multiple family trees)
  familyMemberships PersonFamilyMembership[]

  // Closure table relations
  ancestorIn   PersonAncestry[] @relation("AncestorPerson")
  descendantIn PersonAncestry[] @relation("DescendantPerson")

  @@index([familyId])
  @@index([fullName])
}

model ParentChildRelation {
  id             String                  @id @default(cuid())
  parentPersonId String
  childPersonId  String
  relationType   ParentChildRelationType @default(BIOLOGICAL)
  confidence     RelationConfidence      @default(VERIFIED)
  createdAt      DateTime                @default(now())

  parent Person @relation("ParentPerson", fields: [parentPersonId], references: [id], onDelete: Cascade)
  child  Person @relation("ChildPerson", fields: [childPersonId], references: [id], onDelete: Cascade)

  @@unique([parentPersonId, childPersonId])
  @@index([parentPersonId])
  @@index([childPersonId])
  @@index([relationType])
  @@index([confidence])
}

model MarriageRelation {
  id                   String              @id @default(cuid())
  personAId            String
  personBId            String
  marriageDate         DateTime?
  divorceDate          DateTime?
  status               MarriageStatus      @default(ACTIVE)
  endReason            MarriageEndReason?
  confidence           RelationConfidence  @default(VERIFIED)
  notes                String?
  crossFamilyRequestId String?
  revokedAt            DateTime?
  revokedByUserId      String?
  revocationReason     String?
  supersededById       String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deletedAt            DateTime?

  personA       Person          @relation("MarriagePersonA", fields: [personAId], references: [id], onDelete: Cascade)
  personB       Person          @relation("MarriagePersonB", fields: [personBId], references: [id], onDelete: Cascade)
  supersededBy  MarriageRelation? @relation("MarriageSuperseded", fields: [supersededById], references: [id])
  supersessions MarriageRelation[] @relation("MarriageSuperseded")

  // Partial unique index for active marriages is managed via raw SQL migration
  // (LEAST/GREATEST on personAId,personBId WHERE status='ACTIVE' AND deletedAt IS NULL)
  @@index([personAId])
  @@index([personBId])
  @@index([status])
  @@index([confidence])
  @@index([crossFamilyRequestId])
}

// Closure Table for efficient ancestor/descendant queries
model PersonAncestry {
  id           String @id @default(cuid())
  ancestorId   String
  descendantId String
  depth        Int    // 0 = self, 1 = parent, 2 = grandparent, etc.

  ancestor   Person @relation("AncestorPerson", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Person @relation("DescendantPerson", fields: [descendantId], references: [id], onDelete: Cascade)

  @@unique([ancestorId, descendantId])
  @@index([ancestorId])
  @@index([descendantId])
}

// Secondary membership: person appears in another family's tree without changing primary familyId
// Created automatically by:
//   • applyCrossMarriageRequest  → MARRIED_IN for both spouses in each other's family
//   • applyBranchUnification     → BRANCH_MEMBER for moved persons in source family
//   • addParentChildRelation (cross-family) → CROSS_PARENT + DESCENDANT memberships
model PersonFamilyMembership {
  id        String               @id @default(cuid())
  personId  String
  familyId  String
  role      PersonMembershipRole
  addedAt   DateTime             @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([personId, familyId])
  @@index([familyId])
  @@index([personId])
}

// ===========================
// REQUESTS & GOVERNANCE
// ===========================

model EditRequest {
  id                  String              @id @default(cuid())
  requestType         EditRequestType
  targetType          TargetType
  targetId            String?
  familyId            String
  submittedByUserId   String?
  source              EditRequestSource   @default(MEMBER)
  guestName           String?
  guestContact        String?
  payloadJson         Json
  status              EditRequestStatus   @default(PENDING)
  reviewNotes         String?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  family           Family  @relation(fields: [familyId], references: [id])
  submittedBy      User?   @relation("EditRequestSubmitter", fields: [submittedByUserId], references: [id])
  reviewedBy       User?   @relation("EditRequestReviewer", fields: [reviewedByUserId], references: [id])

  @@index([familyId, status])
  @@index([submittedByUserId])
  @@index([familyId, source, status])
}

model AdminRequest {
  id                    String             @id @default(cuid())
  requestType           AdminRequestType
  targetFamilyId        String?
  targetPersonId        String?
  proposedFamilyName    String?
  proposedHomelandCountry String?
  proposedHomelandRegion  String?
  proposedHomelandCity    String?
  proposedHomelandNote    String?
  proposedHomelandConfidence HomelandConfidence?
  proposedHomelandPlaceId String?
  applicantRelationship   String?
  applicantMessage        String?
  applicantContactEmail   String?
  applicantContactPhone   String?
  submittedByUserId     String
  currentReviewerUserId String?
  status                AdminRequestStatus @default(PENDING)
  decisionType          AdminDecisionType?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  targetFamily  Family? @relation(fields: [targetFamilyId], references: [id])
  targetPerson  Person? @relation("AdminRequestTargetPerson", fields: [targetPersonId], references: [id])
  proposedHomelandPlace HomelandPlace? @relation("AdminRequestProposedHomelandPlace", fields: [proposedHomelandPlaceId], references: [id], onDelete: SetNull)
  submittedBy   User    @relation("AdminRequestSubmitter", fields: [submittedByUserId], references: [id])
  reviewedBy    User?   @relation("AdminRequestReviewer", fields: [currentReviewerUserId], references: [id])

  @@index([status])
  @@index([submittedByUserId])
  @@index([targetFamilyId])
  @@index([proposedHomelandPlaceId])
}

model HomelandPlaceRequest {
  id                 String                     @id @default(cuid())
  countryName        String
  regionName         String?
  cityName           String?
  note               String?
  status             HomelandPlaceRequestStatus @default(PENDING)
  submittedByUserId  String
  reviewedByUserId   String?
  approvedPlaceId    String?
  reviewNotes        String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  submittedBy User           @relation("HomelandPlaceRequestSubmitter", fields: [submittedByUserId], references: [id])
  reviewedBy  User?          @relation("HomelandPlaceRequestReviewer", fields: [reviewedByUserId], references: [id])
  approvedPlace HomelandPlace? @relation("HomelandPlaceRequestApprovedPlace", fields: [approvedPlaceId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([submittedByUserId])
  @@index([approvedPlaceId])
}

model BranchUnificationRequest {
  id              String                       @id @default(cuid())
  sourceFamilyId  String
  targetFamilyId  String
  sourcePersonId  String
  targetPersonId  String
  relationship    BranchUnificationRelationship
  sharedFatherName String?
  sharedMotherName String?
  notes           String?
  status          BranchUnificationStatus      @default(PENDING)

  submittedByUserId String
  sourceApprovedByUserId String?
  sourceApprovedAt DateTime?
  targetApprovedByUserId String?
  targetApprovedAt DateTime?
  rejectedByUserId String?
  rejectedAt DateTime?
  reviewNotes String?
  appliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceFamilyId, status])
  @@index([targetFamilyId, status])
  @@index([submittedByUserId])
}

// Tracks nursing (رضاعة) relationships for mahram calculations
// A FosterRelation means `childPersonId` was nursed by `nursingMotherPersonId`
// The `nursingFatherId` is the husband of the nursing mother at the time of nursing
// (he becomes the foster father — أب من الرضاعة)
model FosterRelation {
  id                  String                    @id @default(cuid())
  childPersonId       String
  nursingMotherPersonId String
  nursingFatherId     String?
  confidence          FosterRelationConfidence  @default(DOCUMENTED)
  notes               String?
  createdByUserId     String
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  deletedAt           DateTime?

  @@index([childPersonId])
  @@index([nursingMotherPersonId])
  @@index([nursingFatherId])
  @@unique([childPersonId, nursingMotherPersonId])
}

model CrossFamilyMarriageRequest {
  id                      String                    @id @default(cuid())
  familyAId               String
  familyBId               String
  personAId               String
  personBId               String
  status                  CrossFamilyMarriageStatus @default(PENDING_FAMILY_B)
  marriageDate            DateTime?
  notes                   String?
  submittedByUserId       String
  familyAApprovedAt       DateTime?
  familyAApprovedByUserId String?
  familyBApprovedAt       DateTime?
  familyBApprovedByUserId String?
  rejectedAt              DateTime?
  rejectedByUserId        String?
  rejectionReason         String?
  appliedAt               DateTime?
  appliedMarriageId       String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([familyAId, status])
  @@index([familyBId, status])
  @@index([submittedByUserId])
  @@index([personAId])
  @@index([personBId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

model Complaint {
  id              String          @id @default(cuid())
  submittedByUserId String
  familyId        String?
  type            ComplaintType
  status          ComplaintStatus @default(OPEN)
  title           String
  body            String
  adminResponse   String?
  handledByUserId String?
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  submittedBy User    @relation("ComplaintSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  handledBy   User?   @relation("ComplaintHandler", fields: [handledByUserId], references: [id])
  family      Family? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([submittedByUserId, createdAt])
  @@index([familyId])
}

// ===========================
// SHARE LINKS
// ===========================

model ShareLink {
  id               String              @id @default(cuid())
  targetType       ShareLinkTargetType
  familyId         String?
  workspaceId      String?
  token            String              @unique @default(cuid())
  passwordHash     String?
  expiresAt        DateTime?
  isActive         Boolean             @default(true)
  createdByUserId  String
  createdAt        DateTime            @default(now())

  createdBy User       @relation(fields: [createdByUserId], references: [id])
  family    Family?    @relation(fields: [familyId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([token])
  @@index([familyId])
  @@index([workspaceId])
}
