+                  dir="rtl"
+                >
+                  <UserPlus className="h-3.5 w-3.5" />
+                  إضافة شخص
+                </button>
+              )}
+            </Panel>
+          )}
+        </ReactFlow>
+      </div>
     </div>
   );
 }
