NODE_ENV=production
PORT=9322

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/families_tree?sslmode=verify-full"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
AUTH_URL="https://teranoo.com/api/auth"
NEXTAUTH_URL="https://teranoo.com/api/auth"
SYSTEM_ADMIN_EMAILS=""

AUTH_GOOGLE_ID="replace-with-production-client-id"
AUTH_GOOGLE_SECRET="replace-with-production-client-secret"

NEXT_PUBLIC_APP_URL="https://teranoo.com/bustanalosool"
NEXT_PUBLIC_BASE_PATH="/bustanalosool"

# Optional seed bootstrap admin. Leave unset in production unless this is a controlled one-time bootstrap.
SEED_SYSTEM_ADMIN_EMAIL=""
SEED_SYSTEM_ADMIN_PASSWORD=""
SEED_SYSTEM_ADMIN_NAME=""
